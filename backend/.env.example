# URL de l'instance Prometheus
PROMETHEUS_URL=http://localhost:9090

# Clé API simple pour sécuriser les endpoints (optionnel en dev)
API_KEY=atlas-secret-key

# Port du serveur backend
PORT=4000

# Mode simulation : true = données fictives (utile sans Prometheus)
MOCK_MODE=true

# URL Grafana (pour génération de liens vers les dashboards)
GRAFANA_URL=http://localhost:3000

# Intervalles de polling en secondes
SCRAPE_INTERVAL=15
ALERT_CHECK_INTERVAL=30
